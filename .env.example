# Supabase — the URL and publishable key have safe in-code defaults, so these
# are optional overrides. All public writes are constrained by row-level security.
NEXT_PUBLIC_SUPABASE_URL=https://hvczjjshhsjpytqlbvel.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Your Substack (used by the header/footer links)
NEXT_PUBLIC_SUBSTACK_URL=https://functionalintelligence.substack.com

# Stripe — leave unset for launch mode (backings are recorded as unpaid
# pledges). Set all three to switch The Board to real payments:
#   1. STRIPE_SECRET_KEY: Stripe dashboard → Developers → API keys
#   2. STRIPE_WEBHOOK_SECRET: create a webhook for checkout.session.completed
#      pointed at https://<your-domain>/api/stripe/webhook
#   3. SUPABASE_SERVICE_ROLE_KEY: Supabase dashboard → Settings → API
#      (server-only; lets the webhook record 'paid' backings)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
